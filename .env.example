# ─── Application ────────────────────────────────────────────────────────────
AIMW_ENV=development
AIMW_LOG_LEVEL=INFO
AIMW_LOG_JSON=true
AIMW_API_PREFIX=/api/v1

# ─── Storage ───────────────────────────────────────────────────────────────
AIMW_STORAGE_DIR=./storage
AIMW_MAX_UPLOAD_MB=512
AIMW_ALLOWED_EXTENSIONS=mp4,mov,webm

# ─── Database ──────────────────────────────────────────────────────────────
AIMW_DATABASE_URL=postgresql+psycopg://aimw:aimw@localhost:5432/aimw

# ─── Redis / Celery ────────────────────────────────────────────────────────
AIMW_REDIS_URL=redis://localhost:6379/0
AIMW_CELERY_BROKER_URL=redis://localhost:6379/1
AIMW_CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Pipeline ──────────────────────────────────────────────────────────────
# Provider selection: "mock" (no GPU, deterministic) or "real".
# Visual also accepts "none" (no VLM, emits no detections) for the sovereign
# CPU profile — unlike "mock" it never fabricates evidence.
AIMW_OCR_PROVIDER=mock
AIMW_SPEECH_PROVIDER=mock
AIMW_VISUAL_PROVIDER=mock
AIMW_FRAMES_PER_SECOND=1.0
AIMW_FUSION_WINDOW_SECONDS=1.5
# OCR is the dominant cost. Strategy: all | keyframes | dedup (recommended).
AIMW_OCR_FRAME_STRATEGY=dedup
AIMW_OCR_DEDUP_HAMMING=6
# Lighter PaddleOCR mobile models + no doc preprocessing (~3x faster per frame).
# Set model names empty to use PaddleOCR's bundled defaults.
AIMW_OCR_LANG=en
AIMW_OCR_MIN_CONFIDENCE=0.5
AIMW_OCR_DET_MODEL_NAME=PP-OCRv5_mobile_det
AIMW_OCR_REC_MODEL_NAME=PP-OCRv5_mobile_rec
AIMW_OCR_USE_DOC_PREPROCESSING=false
# GPU batching: set device=gpu and a larger batch on GPU nodes for a big speedup.
AIMW_OCR_DEVICE=cpu
AIMW_OCR_BATCH_SIZE=8

# ─── Speech (Whisper / faster-whisper) ──────────────────────────────────────
# GPU: device=cuda, compute_type=float16. CPU: device=cpu, compute_type=int8.
# Smaller models (base/small/medium) are far faster on CPU than large-v3.
# distil-large-v3 is ~6x faster than large-v3 at near-equal accuracy.
AIMW_WHISPER_MODEL=large-v3
AIMW_WHISPER_DEVICE=auto
AIMW_WHISPER_COMPUTE_TYPE=int8
AIMW_WHISPER_VAD_FILTER=true
AIMW_WHISPER_BEAM_SIZE=1
AIMW_WHISPER_BATCHED=true
AIMW_WHISPER_BATCH_SIZE=8

# ─── Visual (Qwen2.5-VL via OpenRouter) ─────────────────────────────────────
AIMW_VISUAL_MODEL=qwen/qwen2.5-vl-72b-instruct
AIMW_VISUAL_MAX_CONCURRENCY=4
# Stage-gating the VLM (each keyframe is a paid call): off | dedup | text_risk.
# dedup = analyze only visually-distinct keyframes (default, no recall loss).
# text_risk = also require an OCR/speech risk hit nearby (most savings; falls
# back to dedup set when text is silent so visual-only risk is never missed).
AIMW_VISUAL_GATING=dedup
AIMW_VISUAL_DEDUP_HAMMING=6
AIMW_VISUAL_GATING_WINDOW_SECONDS=3.0
AIMW_VISUAL_MAX_KEYFRAMES=0

# ─── Semantic matcher (local embeddings, no external API) ───────────────────
# Optional additive text-risk source that catches paraphrased scams the lexicon
# misses. Runs on CPU, no data leaves the box. off | local.
AIMW_SEMANTIC_PROVIDER=off
AIMW_SEMANTIC_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
AIMW_SEMANTIC_THRESHOLD=0.6
AIMW_SEMANTIC_WEIGHT=0.8
AIMW_SEMANTIC_DEVICE=cpu

# ─── Reasoning engine (OpenRouter) ─────────────────────────────────────────
AIMW_OPENROUTER_API_KEY=sk-or-changeme
AIMW_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AIMW_REASONING_MODEL=qwen/qwen-2.5-72b-instruct
AIMW_REASONING_TIMEOUT_SECONDS=120
AIMW_REASONING_MAX_RETRIES=3
# Skip the paid 72B judge when fusion found no evidence (return empty verdict).
AIMW_REASONING_SKIP_WHEN_EMPTY=true
# Faster judge cascade: fast 32B first, escalate to AIMW_REASONING_MODEL only
# when the fast judge is unsure. Set escalation=false to use one model directly
# (point AIMW_REASONING_MODEL at qwen/qwen3-32b for pure speed).
AIMW_REASONING_FAST_MODEL=qwen/qwen3-32b
AIMW_REASONING_ESCALATION=true
AIMW_REASONING_ESCALATION_CONFIDENCE=0.6
# Allow the pipeline to finish with a deterministic fallback verdict when the
# judge is unreachable. Disable in strict-compliance deployments.
AIMW_REASONING_ALLOW_FALLBACK=true

# ─── Webhooks ──────────────────────────────────────────────────────────────
AIMW_WEBHOOK_TIMEOUT_SECONDS=10
AIMW_WEBHOOK_MAX_RETRIES=3
AIMW_WEBHOOK_SIGNING_SECRET=change-me-webhook-secret

# ─── Sovereign CPU profile (no external AI APIs, data stays on-box) ──────────
# For governmental / data-residency deployments with no GPU. Copy these over the
# defaults above. Local OCR + Whisper + semantic matcher do the analysis; the
# judge runs as the deterministic on-box fallback (leave the placeholder API key
# so no OpenRouter call is ever made); visual is disabled (no VLM available).
#   AIMW_OCR_PROVIDER=real
#   AIMW_SPEECH_PROVIDER=real
#   AIMW_VISUAL_PROVIDER=none
#   AIMW_SEMANTIC_PROVIDER=local
#   AIMW_OPENROUTER_API_KEY=sk-or-changeme   # placeholder -> deterministic fallback judge
#   AIMW_WHISPER_MODEL=small                 # CPU-friendly; large-v3 is slow without a GPU
